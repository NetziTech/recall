{
  "name": "mcp-memoria",
  "version": "0.1.0-alpha.0",
  "description": "MCP server for project-scoped, self-curated memory with hybrid search.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "mcp-memoria-server": "./dist/server.js",
    "mcp-memoria": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "lint:tests": "eslint tests scripts --max-warnings 0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "validate:modules": "tsx scripts/validate-modules.ts",
    "sonar": "sonar-scanner",
    "ci": "npm run typecheck && npm run lint && npm run validate:modules && npm run test:coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/hashes": "^2.0.0",
    "better-sqlite3-multiple-ciphers": "^12.0.0",
    "commander": "^12.0.0",
    "fastembed": "^2.0.0",
    "pino": "^10.0.0",
    "sqlite-vec": "^0.1.6",
    "tiktoken": "^1.0.0",
    "uuid": "^11.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
