{
  "name": "@netzi/recall",
  "version": "0.1.2",
  "description": "MCP server for project-scoped, self-curated memory with hybrid search (BM25 + sqlite-vec).",
  "type": "module",
  "license": "MIT",
  "author": "Netzi Tech",
  "homepage": "https://github.com/NetziTech/recall#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NetziTech/recall.git",
    "directory": "code"
  },
  "bugs": {
    "url": "https://github.com/NetziTech/recall/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "memory",
    "claude",
    "agent",
    "context",
    "sqlite",
    "fts5",
    "sqlite-vec",
    "hybrid-search",
    "ddd",
    "clean-architecture"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "recall-server": "dist/server.js",
    "recall": "dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "lint:tests": "eslint tests scripts --max-warnings 0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "validate:modules": "tsx scripts/validate-modules.ts",
    "sonar": "sonar-scanner",
    "ci": "npm run typecheck && npm run lint && npm run validate:modules && npm run test:coverage",
    "postinstall": "patch-package",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run validate:modules && npm run build && npm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/hashes": "^2.0.0",
    "bech32": "^2.0.0",
    "better-sqlite3-multiple-ciphers": "^12.0.0",
    "commander": "^14.0.3",
    "fastembed": "^2.0.0",
    "pino": "^10.0.0",
    "sqlite-vec": "^0.1.6",
    "tiktoken": "^1.0.0",
    "uuid": "^14.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.7.0",
    "@vitest/coverage-istanbul": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.2.1",
    "patch-package": "^8.0.1",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.6"
  }
}
